{
    "name": "thuydx/abac",
    "description": "Attribute Based Access Control (ABAC) package for Laravel",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "ThuyDX",
            "email": "me@thuydx.pro"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "ThuyDX\\ABAC\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ThuyDX\\ABAC\\Providers\\AbacServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
